{
  "name": "brennan-pricing-tool",
  "version": "0.1.2",
  "description": "Brennan Industries Part Cost Lookup Tool (interim, CSV-fed)",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "package": "vite build && electron-builder --win portable",
    "test": "vitest run"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.brennan.pricingtool",
    "productName": "Brennan Pricing Tool",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "artifactName": "BrennanPricingTool-${version}.${ext}"
    }
  }
}
